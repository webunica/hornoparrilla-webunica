

<div {% render 'section-attr' %}>
  {% render 'section-bg-image' %}
  <xo-container
    {% render 'section-layout' %}
  >
    <xo-animate>
      <div class='banner-v184'>
        <div class='banner-v184__item'>
          <div class='banner-v184__border'>
            <div class='banner-v184__text'>
              <p class='banner-v184__subtitle'>{{ section.settings.subtitle }}</p>
              <h3 class='banner-v184__title'>{{ section.settings.title }}</h3>
              <p class='banner-v184__description'>{{ section.settings.description }}</p>
              {% render 'button',
                text: section.settings.button_text,
                link: section.settings.link_banner,
                mode: section.settings.button_mode,
                style: section.settings.button_style,
                size: section.settings.button_size,
                radius: section.settings.button_radius,
                padding: section.settings.button_padding
              %}
            </div>
          </div>
        </div>
      </div>
    </xo-animate>
  </xo-container>
</div>

{% schema %}
{
