

{%- assign reversed = section.settings.reversed -%}

{% comment %} Assign align. Align will get 3 values : start , center or end {% endcomment %}
{% comment %} {%- assign align = section.settings.align | default: 'start' -%} {% endcomment %}

<div class='banner-v207'>
  <div
    {% render 'section-attr' %}
  >
    {% render 'section-bg-image' %}
    <xo-container
      {% render 'section-layout' %}
    >
      <xo-animate xo-cascade>
        <xo-grid
          style='--xs:1;--md:2;--xo-grid-col-gap:{{ section.settings.gap }}px ;--xo-grid-row-gap:{{ section.settings.gap }}px ;'
        >
          <div
            class='banner-v207__item banner-v207__item--left'
            {% if reversed %}
              style='--order-xs: 1;--order-sm:1'
            {% endif %}
          >
            <div class='banner-v207__item-wrap'>
              <div class='{%- render 'hover-style' -%}'>
                <a href='{{ section.settings.link_banner1 }}' class='banner-v207__img'>
                  {%- render 'image', image: section.settings.image1 -%}
                </a>
                <div class='banner-v207__content'>
                  <h3 class='banner-v207__title'>{{ section.settings.title1 }}</h3>
                  <div class='banner-v207__desc'>{{ section.settings.description1 }}</div>
                </div>
              </div>
            </div>
          </div>
        </xo-grid>
      </xo-animate>
    </xo-container>
  </div>
</div>

