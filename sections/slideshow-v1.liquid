

<section class='{{ 'xo-section--' | append: section.id }}'>
  <xo-container {% render 'section-layout' %}>
    <xo-grid
      style='
        --height-desktop: {{ section.settings.section_height_desktop }};
        --height-mobile: {{ section.settings.section_height_mobile }};
        --pt: {{ section.settings.padding_top }};
        --pb: {{ section.settings.padding_bottom }};
        --gap: {{ section.settings.gap }}'
      class='slideshow-v23'
    >
      {% if section.settings.reverse_layout == false %}
        {% assign order_column = 0 %}
      {% else %}
        {% assign order_column = -1 %}
      {% endif %}
      <div style='--xs:12;'>
        <xo-carousel
          xo-render-bullet='<span></span>'
          xo-type='{{ section.settings.carousel_type }}'
          {% if section.settings.autoplay %}
            xo-autoplay='{{ section.settings.autoplay_speed | times: 1000 }}'
          {% endif %}
          xo-speed='{{ section.settings.changing_speed }}'
          xo-loop
          xo-hover-pause
        >
          <xo-carousel-inner>
            <xo-carousel-list>
              {% for block in section.blocks %}
                <xo-carousel-slide>
                  <div {% render 'slideshow-attr', block: block %}>
                    {% render 'slideshow-bg-image', block: block %}
                      <xo-grid class='slideshow-v23__content'>
                        <div style='--xs: 12; --start-md: 2; --md: 6;'  class='slideshow-v23__text'>
                          {%- capture title -%}
                            {%- if block.settings.title != blank -%}
                              <h2 class='slideshow-v23__title' style='--fontsize:{{block.settings.title_font_size}}; --fontweight:{{block.settings.title_font_weight}}'>
                                {{ block.settings.title }}
                              </h2>
                            {%- endif -%}
                          {%- endcapture -%}
                          {%- capture description -%}
                            {%- if block.settings.description != blank -%}
                              <p class='slideshow-v23__description' style='--fontsize:{{block.settings.description_font_size}}; --fontweight:{{block.settings.description_font_weight}}'>
                                {{ block.settings.description }}
                              </p>
                            {%- endif -%}
                          {%- endcapture -%}
                          {%- capture button -%}
                            {%- if block.settings.button_text != blank -%}
                              {% render 'button',
                                text: block.settings.button_text,
                                link: block.settings.button_link,
                                mode: block.settings.button_mode,
                                style: block.settings.button_style,
                                size: block.settings.button_size,
                                radius: block.settings.button_radius,
                                padding: block.settings.button_padding
                              %}
                            {%- endif -%}
                          {%- endcapture -%}

                          {%- render 'animation', content: title, type: block.settings.title_animation, order: 1, duration: '700' -%}
                          {%- render 'animation', content: description, type: block.settings.description_animation, order: 3, duration: '700' -%}
                          {%- render 'animation', content: button, type: block.settings.button_animation, order: 5, duration: '700', strength: 3 -%}
                        </div>

                        {% if section.settings.show_pagination %}
                          {% render 'carousel-pagination-style3', class: 'slideshow-v23__pagination' %}
                        {% endif %}
                      </xo-grid>
                  </div>
                </xo-carousel-slide>
              {% endfor %}
            </xo-carousel-list>
          </xo-carousel-inner>
        </xo-carousel>
      </div>
    </xo-grid>
  </xo-container>

</section>

