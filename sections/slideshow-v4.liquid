

<section class='{{ 'xo-section--' | append: section.id }}'>
  <xo-carousel
    xo-render-bullet='<span></span>'
    xo-type='{{ section.settings.carousel_type }}'
    {% if section.settings.autoplay %}
      xo-autoplay='{{ section.settings.autoplay_speed | times: 1000 }}'
    {% endif %}
    xo-speed='{{ section.settings.changing_speed }}'
    xo-loop
    xo-hover-pause
  >
    <xo-carousel-inner>
      <xo-carousel-list>
        {% for block in section.blocks %}
          <xo-carousel-slide>
            <div {% render 'slideshow-attr', block: block %}>
              {% render 'slideshow-bg-image', block: block %}
              <xo-container {% render 'section-layout' %}>
                <div
                  style='
                    --height-desktop: {{ section.settings.section_height_desktop }};
                    --height-mobile: {{ section.settings.section_height_mobile }};
                    --pt: {{ section.settings.padding_top }};
                    --pb: {{ section.settings.padding_bottom }};
                  '
                  class='slideshow-v50__content'
                >
                  <div class='slideshow-v50__text'>
                    {%- capture subtitle -%}
                      {%- if block.settings.subtitle != blank -%}
                        <div class='slideshow-v50__subtitle' style='--fontsize:{{block.settings.subtitle_font_size}}; --fontweight:{{block.settings.subtitle_font_weight}}'>
                          {{ block.settings.subtitle }}
                        </div>
                      {%- endif -%}
                    {%- endcapture -%}
                    {%- capture title  -%}
                      {%- if block.settings.title != blank -%}
                        <h2 class='slideshow-v50__title' style='--fontsize:{{block.settings.title_font_size}}; --fontweight:{{block.settings.title_font_weight}}'>
                          {{ block.settings.title }}
                        </h2>
                      {%- endif -%}
                    {%- endcapture -%}
                    {%- capture description -%}
                      {%- if block.settings.description != blank -%}
                        <p class='slideshow-v50__description' style='--fontsize:{{block.settings.description_font_size}}; --fontweight:{{block.settings.description_font_weight}}'>
                          {{ block.settings.description }}
                        </p>
                      {%- endif -%}
                    {%- endcapture -%}
                    {%- capture button -%}
                      {%- if block.settings.button_text != blank -%}
                        {% render 'button',
                          text: block.settings.button_text,
                          link: block.settings.button_link,
                          mode: block.settings.button_mode,
                          style: block.settings.button_style,
                          size: block.settings.button_size,
                          radius: block.settings.button_radius,
                          padding: block.settings.button_padding
                        %}
                      {%- endif -%}
                    {%- endcapture -%}

                    {%- render 'animation', content: subtitle, type: block.settings.subtitle_animation, order: 1, duration: '700' -%}
                    {%- render 'animation', content: title, type: block.settings.title_animation, order: 3, duration: '700' -%}
                    {%- render 'animation', content: description, type: block.settings.description_animation, order: 5, duration: '700'-%}
                    {%- render 'animation', content: button, type: block.settings.button_animation, order: 7, duration: '700', strength: 3 -%}
                  </div>
                  {%- if section.settings.show_pagination -%}
                    {% render 'carousel-pagination-style3', class: 'slideshow-v50__pagination' %}
                  {%- endif -%}
                </div>
                {% if section.settings.show_navigation %}
                  <div class='slideshow-v50__arrows'>
                    {% render 'carousel-navigation-style3' %}
                  </div>
                {% endif %}
              </xo-container>
            </div>
          </xo-carousel-slide>
        {% endfor %}
      </xo-carousel-list>
    </xo-carousel-inner>
  </xo-carousel>
</section>

