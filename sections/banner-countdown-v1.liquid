

<section {% render 'section-attr' %}>
  {% render 'section-bg-image' %}
  <xo-container {% render 'section-layout' %}>
    <xo-grid>
      <div
        class='banner-countdown-v5__content'
        style='
          --xs: 12; --md: 5; {% if section.settings.reverse %}
            --start-md: 8;
          {% endif %}
        '
      >       
        <div class='banner-countdown-v5__countdown'>
          <xo-animate xo-cascade>          
            {% if section.settings.countdown_subtitle != blank %}
              <div class='banner-countdown-v5__countdown-subtitle'>
                {{ section.settings.countdown_subtitle }}
              </div>
            {% endif %}
             <div class='banner-countdown-v5__countdown-title'>
              {{ section.settings.countdown_title }}
            </div>
          </xo-animate>
          <xo-animate xo-cascade>
          <h2 class='banner-countdown-v5__title'>{{ section.settings.title }}</h2>
        </xo-animate>
          {% assign timestamp = section.settings.countdown_time | date: '%s' | append: '000' %}
          <xo-countdown xo-timestamp='{{ timestamp }}' xo-zero-pad='2' class='banner-countdown-v5__countdown-time'>
            {% if section.settings.show_days %}
              <xo-animate xo-cascade class='banner-countdown-v5__item'>
                <xo-countdown-day class='banner-countdown-v5__number'></xo-countdown-day>
                <span>{{ 'general.countdown.days' | t }}</span>
              </xo-animate>
            {% endif %}
            {% if section.settings.show_hours %}
              <xo-animate xo-cascade class='banner-countdown-v5__item'>
                <xo-countdown-hour class='banner-countdown-v5__number'></xo-countdown-hour>
                <span>{{ 'general.countdown.hours' | t }}</span>
              </xo-animate>
            {% endif %}
            {% if section.settings.show_minutes %}
              <xo-animate xo-cascade class='banner-countdown-v5__item'>
                <xo-countdown-minute class='banner-countdown-v5__number'></xo-countdown-minute>
                <span>{{ 'general.countdown.minutes_short' | t }}</span>
              </xo-animate>
            {% endif %}
            {% if section.settings.show_seconds %}
              <xo-animate xo-cascade class='banner-countdown-v5__item'>
                <xo-countdown-second class='banner-countdown-v5__number'></xo-countdown-second>
                <span>{{ 'general.countdown.seconds_short' | t }}</span>
              </xo-animate>
            {% endif %}
          </xo-countdown>
        </div>

        <xo-animate xo-cascade class='banner-countdown-v5__button'>
          {% render 'button',
            text: section.settings.button_text,
            link: section.settings.product.url,
            mode: section.settings.button_mode,
            style: section.settings.button_style,
            size: section.settings.button_size,
            radius: section.settings.button_radius,
            padding: section.settings.button_padding
          %}
        </xo-animate>
      </div>
      <xo-animate xo-cascade style='--xs: 12; --md: 6; --start-md: 7;{% if section.settings.reverse %} --start-md: 1; --order-md: -1{% endif %}'>
        <a
          href='{{ section.settings.product.url }}'
          class='banner-countdown-v5__image'
        >
          {%- if section.settings.product_image != blank -%}
            {% render 'image', image: section.settings.product_image %}
          {%- else -%}
            {% render 'image', image: section.settings.product.featured_image %}
          {%- endif -%}
        </a>
      </xo-animate>
    </xo-grid>
  </xo-container>
</section>

