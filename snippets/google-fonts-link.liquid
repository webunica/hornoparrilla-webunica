{% comment %}
  Google Fonts — non-blocking async load pattern.
  Using rel=preload + onload avoids render-blocking resources (Lighthouse audit: "Eliminate render-blocking resources").
  noscript fallback ensures fonts load when JS is disabled.
{% endcomment %}

{% if settings.font_heading_selection != 'shopify_fonts' %}
  {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=' | append: settings.font_heading_selection | replace: ' ', '+' | append: ':wght@' | append: settings.font_heading_weight | append: '&display=swap' -%}
  <link rel="preload" as="style" href="{{ heading_font_url }}" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ heading_font_url }}"></noscript>
{% endif %}

