{% comment %}
  Renders enhanced meta tags optimized for Google Chile.
  Includes: OG, Twitter Cards, robots directives, og:locale es_CL.

  Usage:
  {% render 'meta-tags' %}
{% endcomment %}

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
    if product.description != blank
      assign og_description = product.description | strip_html | strip_newlines | truncatewords: 30
    endif
  elsif request.page_type == 'collection'
    if collection.description != blank
      assign og_description = collection.description | strip_html | strip_newlines | truncatewords: 30
    endif
  elsif request.page_type == 'article'
    assign og_type = 'article'
    if article.excerpt_or_content != blank
      assign og_description = article.excerpt_or_content | strip_html | strip_newlines | truncatewords: 30
    endif
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
-%}

<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="es_CL">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200, height: 630 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200, height: 630 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ page_image.alt | default: og_title | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="CLP">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200, height: 630 }}">
{%- endif -%}
